  <diagram id="design-class-diagram" name="Design Class Diagram">
    <mxGraphModel dx="1422" dy="794" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="note3" value="Design class diagram&lt;br&gt;Focus: Spring Boot + REST API implementation structure.&lt;br&gt;Controllers receive HTTP requests; services enforce business rules; repositories access PostgreSQL; clients call external AI APIs." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="400" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="class4" value="&lt;div style=&quot;font-size:10px;color:#666666;&quot;&gt;&amp;lt;&amp;lt;Controller&amp;gt;&amp;gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;AuthController&lt;/b&gt;&lt;/div&gt;&lt;hr size=&quot;1&quot;&gt;/api/auth&lt;br&gt;&lt;hr size=&quot;1&quot;&gt;login(request): LoginResponse&lt;br&gt;register(request): UserResponse&lt;br&gt;getCurrentUser(): CurrentUserResponse&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=center;verticalAlign=top;spacingTop=6;fontSize=12;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="80" y="190" width="260" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="class5" value="&lt;div style=&quot;font-size:10px;color:#666666;&quot;&gt;&amp;lt;&amp;lt;Controller&amp;gt;&amp;gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;ChangeRequestController&lt;/b&gt;&lt;/div&gt;&lt;hr size=&quot;1&quot;&gt;/api/change-requests&lt;br&gt;&lt;hr size=&quot;1&quot;&gt;create(request): ChangeRequestResponse&lt;br&gt;findAll(filters): List&amp;lt;ChangeRequestListItem&amp;gt;&lt;br&gt;findById(id): ChangeRequestDetailResponse&lt;br&gt;updateStatus(id, request): ChangeRequestResponse&lt;br&gt;route(id, request): ChangeRequestResponse&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=center;verticalAlign=top;spacingTop=6;fontSize=12;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="80" y="410" width="260" height="210" as="geometry"/>
        </mxCell>
        <mxCell id="class6" value="&lt;div style=&quot;font-size:10px;color:#666666;&quot;&gt;&amp;lt;&amp;lt;Controller&amp;gt;&amp;gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;AISummaryController&lt;/b&gt;&lt;/div&gt;&lt;hr size=&quot;1&quot;&gt;/api/ai&lt;br&gt;&lt;hr size=&quot;1&quot;&gt;generateSummary(request): AISummaryResponse&lt;br&gt;approveSummary(id, request): AISummaryResponse&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=center;verticalAlign=top;spacingTop=6;fontSize=12;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="80" y="680" width="260" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="class7" value="&lt;div style=&quot;font-size:10px;color:#666666;&quot;&gt;&amp;lt;&amp;lt;Controller&amp;gt;&amp;gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;CommentController&lt;/b&gt;&lt;/div&gt;&lt;hr size=&quot;1&quot;&gt;/api/change-requests/{id}/comments&lt;br&gt;&lt;hr size=&quot;1&quot;&gt;addComment(id, request): CommentResponse&lt;br&gt;getComments(id): List&amp;lt;CommentResponse&amp;gt;&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=center;verticalAlign=top;spacingTop=6;fontSize=12;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="80" y="890" width="260" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="class8" value="&lt;div style=&quot;font-size:10px;color:#666666;&quot;&gt;&amp;lt;&amp;lt;Controller&amp;gt;&amp;gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;AdminController&lt;/b&gt;&lt;/div&gt;&lt;hr size=&quot;1&quot;&gt;/api/admin&lt;br&gt;&lt;hr size=&quot;1&quot;&gt;assignRole(userId, request): UserResponse&lt;br&gt;createDepartment(request): DepartmentResponse&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=center;verticalAlign=top;spacingTop=6;fontSize=12;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="80" y="1100" width="260" height="150" as="geometry"/>
